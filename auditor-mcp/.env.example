# Stellar secret key for the PAYING wallet (starts with S...)
# Fund this account on testnet: https://laboratory.stellar.org/#account-creator?network=test
STELLAR_SECRET_KEY=

# Network — leave as-is for testnet
STELLAR_NETWORK=stellar:testnet

# URL of the auditor-backend gateway (our Express server)
# Matches PORT in auditor-backend/.env (default 3001)
AUDIT_GATEWAY_URL=http://localhost:3001/api/audit

# MCP server metadata (optional)
MCP_SERVER_NAME=auditor-mcp
MCP_SERVER_VERSION=0.1.0
