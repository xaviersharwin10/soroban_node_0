# Your Stellar Testnet public key — this is where 0.15 USDC / 1 XLM payments land
TESTNET_SERVER_STELLAR_ADDRESS=G_YOUR_TESTNET_STELLAR_ADDRESS_HERE

# x402 facilitator — Built on Stellar public testnet facilitator (OpenZeppelin)
# Generate a free API key at: https://channels.openzeppelin.com/testnet/gen
TESTNET_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
TESTNET_FACILITATOR_API_KEY=your-uuid-api-key-here

# Groq API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Model to use for auditing (optional — defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

PORT=3001

# MPP server signing key — any strong random string (used by mppx to sign payment challenges)
MPP_SECRET_KEY=your-strong-random-secret-here

# Demo wallet secret key — used by the web UI demo endpoint to pay on your behalf
# Generate a new Stellar testnet keypair at https://lab.stellar.org and fund with Friendbot
# Then add a USDC trustline and get testnet USDC from https://faucet.circle.com
DEMO_CLIENT_STELLAR_SECRET=S_YOUR_DEMO_CLIENT_SECRET_KEY_HERE
